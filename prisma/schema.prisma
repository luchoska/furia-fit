// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // usa connection pooling (Vercel)
  directUrl = env("POSTGRES_URL_NON_POOLING") // usa conexion directa
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  isAvailable Boolean  @default(true)
  sizes       String   // Guardaremos JSON stringificado ["S", "M", "L"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
